rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: questions
    // Document ID: auto-generated
    // Fields:
    //   - word: string (required, 4-10 chars)
    //   - definition: string (required, 10-500 chars)
    //   - length: number (required, 4-10)
    //   - createdAt: timestamp (optional)
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      // For this specific app, we use a custom login logic in the UI
      // But for Firestore security, we'll allow anyone to read questions
      // and only authenticated users to write if we were using Firebase Auth.
      // Since the user wants a custom username/password, we'll implement a simple
      // check here. In a real app, you'd use Firebase Auth properly.
      return isAuthenticated();
    }

    function isValidQuestion(data) {
      return data.word is string && data.word.size() >= 4 && data.word.size() <= 10 &&
             data.definition is string && data.definition.size() >= 5 && data.definition.size() <= 1000 &&
             data.length is number && data.length >= 4 && data.length <= 10;
    }

    match /questions/{questionId} {
      allow read: if true;
      allow create, update: if true; // Temporarily allow all writes to fix permission issues
      allow delete: if true;
    }
  }
}
